<?xml version="1.0" encoding="utf-8"?>
<widget id="com.esp32controllerpro.app" version="1.0.0"
        xmlns="http://www.w3.org/ns/widgets"
        xmlns:android="http://schemas.android.com/apk/res/android">

    <name>ESP32-C3 Pro</name>
    <description>Dashboard kontrol ESP32-C3 dengan suara dan alarm</description>
    <author email="developer@example.com">Developer</author>

    <content src="index.html" />

    <!-- Izin dasar -->
    <allow-navigation href="http://*/*" />
    <allow-navigation href="https://*/*" />
    <allow-intent href="http://*/*" />
    <allow-intent href="https://*/*" />

    <!-- Izin platform -->
    <platform name="android">
        <preference name="android-targetSdkVersion" value="32" />
        <preference name="android-minSdkVersion" value="22" />
        <preference name="android-compileSdkVersion" value="32" />
        <preference name="GradlePluginKotlinEnabled" value="false" />
        <preference name="AndroidXEnabled" value="true" />

        <!-- Izin yang dibutuhkan aplikasi -->
        <config-file target="AndroidManifest.xml" parent="/manifest">
            <uses-permission android:name="android.permission.RECORD_AUDIO" />
            <uses-permission android:name="android.permission.VIBRATE" />
            <uses-permission android:name="android.permission.WAKE_LOCK" />
            <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
            <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
            <uses-permission android:name="android.permission.INTERNET" />
        </config-file>

        <!-- Channel notifikasi untuk alarm -->
        <config-file target="AndroidManifest.xml" parent="/manifest/application">
            <meta-data android:name="com.google.firebase.messaging.default_notification_channel_id" android:value="esp-alarm-channel" />
        </config-file>
    </platform>

    <!-- Plugin yang dibutuhkan (versi stabil) -->
    <plugin name="cordova-plugin-whitelist" spec="^1.3.5" />
    <plugin name="cordova-plugin-device" spec="^2.1.0" />
    <plugin name="cordova-plugin-vibration" spec="^3.1.1" />
    <plugin name="cordova-plugin-statusbar" spec="^3.0.0" />
    <plugin name="cordova-plugin-splashscreen" spec="^6.0.1" />

    <!-- Plugin background mode -->
    <plugin name="cordova-plugin-background-mode" spec="^0.7.3">
        <variable name="KOTLIN_VERSION" value="1.8.22" />
    </plugin>

    <!-- Plugin notifikasi lokal -->
    <plugin name="cordova-plugin-local-notification" spec="^0.9.0-beta.3" />

    <!-- Plugin izin runtime -->
    <plugin name="cordova-plugin-android-permissions" spec="^1.1.5" />

    <!-- Ikon aplikasi (opsional, gunakan file png di folder res/) -->
    <icon src="res/icon/android/ic_launcher.png" />
</widget>
